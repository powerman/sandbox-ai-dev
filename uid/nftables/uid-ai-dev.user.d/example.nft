# Example user rules for uid-ai-dev firewall.
#
# Install: create /etc/nftables/uid-ai-dev.user.d/ and copy this file there
# (or create your own .nft files).
#
# Reload with:
#   sudo nft -f /etc/nftables/uid-ai-dev.nft

# Output hook, before main filter (blocks + whitelist).
chain user_output_before {
    # Direct connection (no NAT).
    ip daddr 192.168.0.1 tcp dport 9443 accept comment "app"
    # Via Docker / DNAT (port is translated by nat/output before filter/output).
    ct original ip daddr 192.168.0.1 ct original protocol tcp ct original proto-dst 9443 accept comment "app (DNAT)"
}

# Output hook, after main filter, before default deny.
chain user_output_after {
}
